{
  "name": "matthiaswyler/kirby-live-visitors",
  "description": "Display live visitor presence on your Kirby site using Plausible Analytics real-time data",
  "type": "kirby-plugin",
  "version": "1.0.0",
  "license": "MIT",
  "keywords": [
    "getkirby",
    "kirby",
    "kirby-cms",
    "kirby-plugin",
    "plausible",
    "analytics",
    "live-visitors",
    "real-time"
  ],
  "homepage": "https://github.com/matthiaswyler/kirby-live-visitors#readme",
  "authors": [
    {
      "name": "Matthias Wyler",
      "email": "mail@matthiaswyler.com",
      "homepage": "https://matthiaswyler.com"
    }
  ],
  "support": {
    "docs": "https://github.com/matthiaswyler/kirby-live-visitors/blob/main/README.md",
    "issues": "https://github.com/matthiaswyler/kirby-live-visitors/issues",
    "source": "https://github.com/matthiaswyler/kirby-live-visitors"
  },
  "require": {
    "getkirby/composer-installer": "^1.2",
    "php": ">=8.1"
  },
  "config": {
    "allow-plugins": {
      "getkirby/composer-installer": true
    }
  },
  "extra": {
    "installer-name": "kirby-live-visitors",
    "kirby-cms-path": false
  }
}
